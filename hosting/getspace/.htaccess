Options -Indexes
DirectoryIndex index.php index.html

AddType application/xml .xml
AddType application/manifest+json .webmanifest

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Blokady prywatnych i niebezpiecznych plikow.
  RewriteRule (^|/)\.git(?:/|$) - [F,L]
  RewriteRule ^uploads/.*\.(?:php|phtml|php[0-9]?|phar|cgi|pl|py|sh|exe|js|html?|svg|zip)$ - [F,L,NC]

  # Jedna wersja domeny: HTTPS bez www. Nie przekierowuj adresu testowego hostingu.
  RewriteCond %{HTTP_HOST} ^www\.mgoutlet\.pl$ [NC,OR]
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} ^(?:www\.)?mgoutlet\.pl$ [NC]
  RewriteRule ^ https://mgoutlet.pl%{REQUEST_URI} [R=301,L,NE]

  # Panel pozostaje na Netlify, gdzie działa Identity i Git Gateway.
  RewriteRule ^admini/?$ /admin/ [R=301,L,NE]
  RewriteRule ^admin/storage(?:/|$) - [F,L]

  # Dynamiczna mapa strony i automatyczne podstrony produktow.
  RewriteRule ^sitemap\.xml$ sitemap.php [L]
  RewriteRule ^produkt/([a-z0-9-]+)/?$ product.php?slug=$1 [L,QSA]

  # Stare adresy HTML przekierowujemy na publiczne, czyste adresy.
  RewriteCond %{THE_REQUEST} \s/+dom\.html(?:[\s?]) [NC]
  RewriteRule ^dom\.html$ /dom [R=301,L,NE]
  RewriteCond %{THE_REQUEST} \s/+ogrod\.html(?:[\s?]) [NC]
  RewriteRule ^ogrod\.html$ /ogrod [R=301,L,NE]

  # Czyste adresy kategorii.
  RewriteRule ^dom/?$ dom.html [L]
  RewriteRule ^ogrod/?$ ogrod.html [L]
</IfModule>

<FilesMatch "^(?:\.env(?:\..*)?|.*\.(?:bak|backup|old|orig|save|sql|sqlite|db|log|key|pem|crt|zip|tar|gz|7z))$">
  Require all denied
</FilesMatch>

<Files "catalog.php">
  Require all denied
</Files>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType application/manifest+json "access plus 7 days"
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; frame-src https://www.google.com; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"

  <FilesMatch "\.(?:avif|webp|jpe?g|png|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
  </FilesMatch>

  <Files "products.json">
    Header set Cache-Control "no-store, max-age=0"
  </Files>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json application/xml image/svg+xml
</IfModule>
